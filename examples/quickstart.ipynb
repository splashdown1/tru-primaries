```

## Example 3: Research Papers

```python
from tru import TRU

tru = TRU()

# Search arXiv for transformer papers
results = tru.search("transformer attention", source_type="arxiv", limit=20)
for r in results:
    print(f"{r.title[:60]}... ({r.date})")
```

## Example 4: Contradiction Detection

```python
from tru import TRU

tru = TRU()

# Get all contradictions found
contradictions = tru.contradictions()
for c in contradictions:
    if c["verdict"] == "CONTRADICTION":
        print(f"⚠️ {c['claim']}")
        print(f"   {c['contradiction']['description']}")
```

## Example 5: Current Events

```python
from tru import TRU

tru = TRU()

# Get latest AI news
events = tru.current_events(limit=10)
for e in events:
    print(f"[{e['source']}] {e['title']}")
```

## Example 6: Symbol Traceability

```python
from tru import TRU

tru = TRU()

# Check symbol audit
audit = tru.symbol_trace(action="audit")
print(f"Issues: {audit.get('issues_count', 0)}")

# List all symbol claims
claims = tru.symbol_trace(action="list")
for c in claims.get("claims", []):
    print(f"{c['claim_id']}: {c['claim'][:50]}")
```

## Example 7: Batch Verification

```python
from tru import TRU

tru = TRU()

claims = [
    "Anthropic was acquired in 2026",
    "OpenAI released GPT-5",
    "The Temple Institute has five red heifers",
    "NVIDIA achieved AGI",
]

for claim in claims:
    v = tru.verify(claim)
    status = "✓" if v.verdict == "VERIFIED" else "⚠️" if v.verdict == "CONTRADICTION" else "?"
    print(f"{status} {claim[:50]}: {v.verdict} ({v.confidence:.2f})")
```

## Example 8: Export for Training

```python
from tru import TRU

tru = TRU()

# Get all verified facts for training
verified = []
contradictions = tru.contradictions()

for c in contradictions:
    if c["verdict"] == "VERIFIED":
        verified.append({
            "claim": c["claim"],
            "evidence": c["evidence"],
        })

print(f"{len(verified)} verified facts ready for training")

# Export as JSONL
import json
with open("verified_facts.jsonl", "w") as f:
    for v in verified:
        f.write(json.dumps(v) + "\n")
```
